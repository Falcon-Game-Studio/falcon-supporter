# ========================================
# Falcon Supporter — Environment Variables
# COPY FILE NÀY THÀNH .env VÀ ĐIỀN THÔNG TIN
# ========================================

# GitHub Personal Access Token (PAT)
# Lấy tại: https://github.com/settings/tokens
# Cần scope: Models (read) hoặc dùng Fine-grained token
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Model sử dụng (mặc định: gpt-4o-mini)
# Các model khác: gpt-4o, gpt-4.1-mini, gpt-4.1-nano
COPILOT_MODEL=gpt-4o-mini

# MongoDB Connection URI
# Local: mongodb://localhost:27017/falcon_supporter
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/falcon_supporter
MONGO_URI=mongodb://localhost:27017/falcon_supporter
